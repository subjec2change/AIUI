# =============================================================================
# AIUI Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Required (for OpenAI mode):
# ---------------------------------------------------------------------------
# Your OpenAI API key. Required when AI_PROVIDER=openai.
# Not needed when using Ollama (--ollama mode).
OPENAI_API_KEY=your-openai-api-key-here

# ---------------------------------------------------------------------------
# AI Provider Configuration:
# ---------------------------------------------------------------------------
# AI backend to use: "openai" or "ollama"
# openai = OpenAI API (requires OPENAI_API_KEY)
# ollama = Local Ollama server (requires Ollama running)
AI_PROVIDER=openai

# AI completion model to use (OpenAI models)
# Examples: gpt-3.5-turbo, gpt-4, gpt-4-turbo
AI_COMPLETION_MODEL=gpt-3.5-turbo

# ---------------------------------------------------------------------------
# Ollama Configuration (for local AI mode):
# ---------------------------------------------------------------------------
# Model name to use with Ollama (e.g., llama3, mistral, mixtral)
# See https://ollama.ai/library for available models
OLLAMA_MODEL=llama3

# Ollama API base URL
# Use host.docker.internal when running inside Docker
# For local development, you may use http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---------------------------------------------------------------------------
# Speech-to-Text (STT) Provider Configuration:
# ---------------------------------------------------------------------------
# STT backend to use: "openai" or "ollama"
# openai = OpenAI Whisper (requires OPENAI_API_KEY)
# ollama = Local Ollama Whisper model
STT_PROVIDER=openai

# ---------------------------------------------------------------------------
# Text-to-Speech (TTS) Provider Configuration:
# ---------------------------------------------------------------------------
# TTS backend to use:
#   gTTS           - Google Text-to-Speech (free, no API key)
#   ELEVENLABS     - ElevenLabs voice cloning (requires ELEVENLABS_API_KEY)
#   STREAMELEMENTS - StreamElements voice (free)
#   EDGETTS        - Microsoft Edge TTS (free, high quality)
#   OLLAMA         - Local Ollama TTS (requires Ollama running)
TTS_PROVIDER=EDGETTS

# ElevenLabs settings (required when TTS_PROVIDER=ELEVENLABS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE=EXAVITQu4vr4xnSDxMaL

# Edge TTS voice (used when TTS_PROVIDER=EDGETTS)
# See https://learn.microsoft.com/en-us/azure/ai-services/speech-service/reference/text-to-speech for available voices
EDGETTS_VOICE=en-US-EricNeural

# ---------------------------------------------------------------------------
# General Settings:
# ---------------------------------------------------------------------------
# ISO-639-1 language code for TTS and AI responses
# Only certain languages are supported by gTTS and edge_tts providers
# Default: en
LANGUAGE=en

# Maximum number of worker processes
MAX_WORKERS=5
